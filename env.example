<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Estúdio de Arte IA</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg:#0e0b1a; --bg2:#16112a; --bg3:#1e1838; --bg4:#251f40;
      --border:rgba(255,255,255,0.08); --border2:rgba(127,119,221,0.40);
      --purple:#7F77DD; --pl:#AFA9EC; --pd:rgba(127,119,221,0.15);
      --coral:#D85A30; --teal:#1D9E75; --amber:#EF9F27;
      --text:#f0eeff; --t2:rgba(240,238,255,0.55); --t3:rgba(240,238,255,0.30);
      --r:14px; --rs:9px;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;min-height:100vh;padding-bottom:4rem}

    /* HEADER */
    .header{background:linear-gradient(135deg,#12082a,#1a0f3a 60%,#0e1a2e);border-bottom:1px solid var(--border);padding:2rem 1.5rem 1.5rem;position:relative;overflow:hidden}
    .orb{position:absolute;border-radius:50%;filter:blur(70px);opacity:.15;pointer-events:none}
    .h-inner{position:relative;z-index:1;max-width:720px;margin:0 auto}
    .eyebrow{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--pl);background:var(--pd);border:1px solid rgba(127,119,221,.25);padding:4px 12px;border-radius:20px;margin-bottom:12px}
    .header h1{font-family:'Space Grotesk',sans-serif;font-size:clamp(20px,5vw,30px);font-weight:700;background:linear-gradient(135deg,#fff 30%,#AFA9EC);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:8px}
    .header p{font-size:13px;color:var(--t2);margin-bottom:14px}
    .badges{display:flex;gap:6px;flex-wrap:wrap}
    .badge{font-size:11px;font-weight:500;padding:3px 10px;border-radius:20px;border:1px solid;color:rgba(255,255,255,.8)}
    .bp{background:rgba(127,119,221,.12);border-color:rgba(127,119,221,.35)}
    .bc{background:rgba(216,90,48,.12);border-color:rgba(216,90,48,.35)}
    .bt{background:rgba(29,158,117,.12);border-color:rgba(29,158,117,.35)}
    .ba{background:rgba(239,159,39,.12);border-color:rgba(239,159,39,.35)}

    /* MAIN TABS */
    .main{max-width:720px;margin:0 auto;padding:1.5rem 1.25rem 0}
    .main-tabs{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:1.5rem}
    .main-tab{padding:14px;border-radius:var(--r);border:1px solid var(--border);background:var(--bg2);cursor:pointer;text-align:center;transition:all .15s}
    .main-tab:hover{border-color:var(--border2);background:var(--bg3)}
    .main-tab.active{border-color:var(--purple);background:var(--pd);box-shadow:0 0 20px rgba(127,119,221,.15)}
    .main-tab i{font-size:22px;color:var(--pl);display:block;margin-bottom:5px}
    .main-tab span{font-size:13px;font-weight:700;color:var(--text);display:block}
    .main-tab small{font-size:11px;color:var(--t3);display:block;margin-top:2px}

    /* MODULE */
    .module{display:none}.module.active{display:block}

    /* STEPS */
    .steps{display:flex;margin-bottom:1.5rem;background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
    .step{flex:1;padding:11px 6px;text-align:center;cursor:pointer;border-right:1px solid var(--border);transition:background .15s}
    .step:last-child{border-right:none}
    .step:hover{background:var(--bg3)}
    .step.active{background:var(--pd)}
    .step.done .snum{background:var(--teal);color:#fff}
    .snum{width:20px;height:20px;border-radius:50%;font-size:10px;font-weight:700;background:var(--bg4);color:var(--t3);display:flex;align-items:center;justify-content:center;margin:0 auto 3px;transition:all .2s}
    .step.active .snum{background:var(--purple);color:#fff}
    .slabel{font-size:11px;font-weight:600;color:var(--t2);display:block}
    .step.active .slabel{color:var(--text)}

    /* CARD */
    .card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:1.25rem;margin-bottom:1rem}
    .card-title{font-size:13px;font-weight:700;color:var(--text);margin-bottom:1rem;display:flex;align-items:center;gap:8px}
    .card-title i{color:var(--pl);font-size:16px}

    /* FORM */
    .fg{margin-bottom:.9rem}.fg:last-child{margin-bottom:0}
    .flabel{display:flex;align-items:center;gap:6px;font-size:11px;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px}
    input,textarea,select{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:var(--rs);color:var(--text);font-family:'Inter',sans-serif;font-size:14px;padding:10px 12px;outline:none;transition:border-color .15s}
    input::placeholder,textarea::placeholder{color:var(--t3)}
    input:focus,textarea:focus,select:focus{border-color:var(--border2)}
    select option{background:#1e1838}
    textarea{height:72px;resize:vertical}
    .row2{display:grid;grid-template-columns:1fr 1fr;gap:10px}

    /* CHIPS */
    .chips{display:flex;flex-wrap:wrap;gap:6px}
    .chip{display:inline-flex;align-items:center;gap:4px;padding:5px 12px;border-radius:20px;font-size:12px;font-weight:500;border:1px solid var(--border);background:var(--bg3);color:var(--t2);cursor:pointer;transition:all .12s;user-select:none}
    .chip:hover{border-color:var(--border2);color:var(--pl)}
    .chip.on{background:var(--pd);border-color:var(--purple);color:var(--pl)}

    /* COLOR PICKER */
    .color-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}
    .cpick{width:28px;height:28px;border-radius:50%;cursor:pointer;border:2.5px solid transparent;transition:all .12s;flex-shrink:0}
    .cpick.on{border-color:#fff;box-shadow:0 0 0 2px rgba(255,255,255,.25);transform:scale(1.12)}

    /* SCENARIOS */
    .scenarios{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px}
    .scenario-card{border-radius:var(--rs);overflow:hidden;cursor:pointer;border:2px solid var(--border);position:relative;transition:all .15s;background:var(--bg3)}
    .scenario-card:hover{border-color:var(--border2)}
    .scenario-card.active{border-color:var(--purple);box-shadow:0 0 16px rgba(127,119,221,.25)}
    .scenario-thumb{width:100%;height:75px;display:flex;align-items:center;justify-content:center;background:var(--bg4)}
    .scenario-label{padding:6px 8px;font-size:11px;font-weight:600;color:var(--t2);display:flex;align-items:center;gap:5px}
    .scenario-card.active .scenario-label{color:var(--pl)}
    .scenario-check{position:absolute;top:5px;right:5px;width:18px;height:18px;border-radius:50%;background:var(--purple);display:none;align-items:center;justify-content:center;font-size:10px;color:#fff}
    .scenario-card.active .scenario-check{display:flex}

    /* FORMAT CARDS (posts) */
    .formats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
    .fmt-card{border-radius:var(--rs);cursor:pointer;border:2px solid var(--border);background:var(--bg3);padding:14px 8px;text-align:center;transition:all .15s;position:relative}
    .fmt-card:hover{border-color:var(--border2)}
    .fmt-card.active{border-color:var(--purple);background:var(--pd);box-shadow:0 0 14px rgba(127,119,221,.2)}
    .fmt-preview{margin:0 auto 8px;background:var(--bg4);border-radius:4px;border:1px solid var(--border)}
    .fmt-label{font-size:12px;font-weight:700;color:var(--text);display:block}
    .fmt-dim{font-size:10px;color:var(--t3);display:block;margin-top:2px}
    .fmt-card.active .fmt-label{color:var(--pl)}
    .fmt-check{position:absolute;top:5px;right:5px;width:16px;height:16px;border-radius:50%;background:var(--purple);display:none;align-items:center;justify-content:center;font-size:9px;color:#fff}
    .fmt-card.active .fmt-check{display:flex}

    /* TIPO CONTEUDO */
    .tipo-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:8px}
    .tipo-card{border-radius:var(--rs);cursor:pointer;border:1px solid var(--border);background:var(--bg3);padding:12px 8px;text-align:center;transition:all .15s}
    .tipo-card:hover{border-color:var(--border2)}
    .tipo-card.active{border-color:var(--purple);background:var(--pd)}
    .tipo-icon{font-size:22px;display:block;margin-bottom:4px}
    .tipo-label{font-size:11px;font-weight:600;color:var(--t2)}
    .tipo-card.active .tipo-label{color:var(--pl)}

    /* SOURCE TOGGLE */
    .source-btns{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .source-btn{display:flex;flex-direction:column;align-items:center;gap:3px;padding:10px 8px;border-radius:var(--rs);cursor:pointer;border:1px solid var(--border);background:var(--bg3);color:var(--t2);font-family:'Inter',sans-serif;transition:all .15s}
    .source-btn i{font-size:18px}
    .source-btn span{font-size:13px;font-weight:600;color:var(--text)}
    .source-btn small{font-size:10px;color:var(--t3)}
    .source-btn:hover{border-color:var(--border2)}
    .source-btn.active{border-color:var(--purple);background:var(--pd)}
    .source-btn.active span{color:var(--pl)}

    /* FOTO PREVIEW */
    .foto-preview{border-radius:var(--rs);overflow:hidden;position:relative;background:var(--bg3);border:1px solid var(--border);margin-bottom:.8rem}
    .foto-preview img{width:100%;height:180px;object-fit:cover;display:block}
    .foto-credit{position:absolute;bottom:0;left:0;right:0;padding:5px 10px;background:rgba(0,0,0,.5);font-size:10px;color:rgba(255,255,255,.6);display:flex;align-items:center;gap:4px}
    .foto-credit a{color:rgba(255,255,255,.7);text-decoration:none}
    .btn-nova-foto{width:100%;padding:9px;font-size:12px;font-weight:600;border-radius:var(--rs);border:1px solid var(--border);background:var(--bg3);color:var(--t2);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .12s;font-family:'Inter',sans-serif}
    .btn-nova-foto:hover{border-color:var(--border2);color:var(--text)}

    /* BTN PRINCIPAL */
    .btn-gen{width:100%;padding:14px;font-size:15px;font-weight:700;border-radius:var(--r);cursor:pointer;border:none;background:linear-gradient(135deg,#7F77DD,#5e57b5 50%,#D85A30);color:#fff;letter-spacing:.02em;margin-top:.5rem;font-family:'Space Grotesk',sans-serif;transition:opacity .15s,transform .12s;display:flex;align-items:center;justify-content:center;gap:8px}
    .btn-gen:hover{opacity:.88}
    .btn-gen:active{opacity:.75;transform:scale(.99)}
    .btn-gen:disabled{opacity:.4;cursor:not-allowed}
    .btn-back{width:100%;padding:11px;font-size:13px;font-weight:600;border-radius:var(--r);cursor:pointer;border:1px solid var(--border2);background:transparent;color:var(--pl);margin-top:.75rem;font-family:'Inter',sans-serif;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .12s}
    .btn-back:hover{background:var(--pd)}

    /* RESULTADO */
    .result-wrap{margin-top:1.5rem;border-radius:var(--r);overflow:hidden;border:1px solid var(--border)}
    .result-bar{display:flex;align-items:center;justify-content:space-between;padding:10px 16px;background:linear-gradient(90deg,#12082a,#1a0f3a);border-bottom:1px solid var(--border)}
    .sdot{width:8px;height:8px;border-radius:50%;background:var(--amber);flex-shrink:0;transition:background .3s}
    .sdot.ok{background:var(--teal)}.sdot.err{background:#E24B4A}
    .result-bar-l{display:flex;align-items:center;gap:8px}
    .result-bar span{font-size:13px;font-weight:500}
    .rtag{font-size:11px;background:rgba(255,255,255,.08);padding:3px 9px;border-radius:10px;color:var(--t2)}

    /* LOADING */
    .loading-box{padding:3rem 1rem;text-align:center;background:var(--bg2)}
    .spin{width:34px;height:34px;border:2px solid rgba(127,119,221,.2);border-top-color:var(--purple);border-radius:50%;animation:spin .75s linear infinite;margin:0 auto 1rem}
    @keyframes spin{to{transform:rotate(360deg)}}
    .lmsg{font-size:13px;color:var(--t2)}
    .lsteps{display:flex;justify-content:center;gap:6px;margin-top:1rem}
    .lstep{width:7px;height:7px;border-radius:50%;background:var(--border)}
    .lstep.pulse{background:var(--purple);animation:pulse 1s infinite}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.2}}

    /* OUTPUT MOCKUP */
    .output-box{padding:1.25rem;background:var(--bg2)}
    .mockup-wrap{position:relative;border-radius:10px;overflow:hidden;border:1px solid var(--border);margin-bottom:1rem;background:#000}
    .mockup-bg{width:100%;height:260px;object-fit:cover;display:block;filter:brightness(.75)}
    .mockup-overlay{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:1.5rem}
    #svg-canvas{max-width:280px;max-height:170px;width:100%;filter:drop-shadow(0 4px 24px rgba(0,0,0,.7))}
    #svg-canvas svg{max-width:100%;height:auto}
    .mockup-badge{position:absolute;bottom:8px;right:8px;font-size:10px;background:rgba(0,0,0,.5);color:rgba(255,255,255,.5);padding:3px 8px;border-radius:8px;backdrop-filter:blur(4px)}

    /* OUTPUT POST */
    .post-wrap{margin-bottom:1rem}
    .post-frame{border-radius:10px;overflow:hidden;border:1px solid var(--border);background:#000;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;min-height:200px;padding:8px}
    .post-frame svg{max-width:100%;height:auto;display:block;border-radius:6px}

    /* DESC */
    .desc-card{background:var(--pd);border:1px solid rgba(127,119,221,.2);border-radius:10px;padding:1rem;margin-bottom:1rem}
    .desc-label{font-size:10px;font-weight:700;color:var(--pl);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;display:flex;align-items:center;gap:5px}
    .desc-card p{font-size:13px;color:var(--t2);line-height:1.65}

    .action-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
    .action-row-2{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .btn-sec{padding:10px 6px;font-size:12px;font-weight:500;cursor:pointer;border-radius:var(--rs);border:1px solid var(--border);background:var(--bg3);color:var(--text);display:flex;align-items:center;justify-content:center;gap:5px;transition:all .12s;font-family:'Inter',sans-serif}
    .btn-sec:hover{background:var(--bg);border-color:var(--border2)}

    /* ERROR */
    .error-box{padding:2rem 1.25rem;text-align:center;background:var(--bg2)}
    .error-icon{font-size:32px;color:#E24B4A;margin-bottom:10px}
    .error-msg{font-size:13px;color:var(--t2);margin-bottom:1rem;line-height:1.5}
    .btn-retry{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;font-size:13px;font-weight:500;border-radius:var(--rs);cursor:pointer;border:1px solid var(--border2);background:var(--pd);color:var(--pl);font-family:'Inter',sans-serif;transition:all .12s}
    .btn-retry:hover{background:rgba(127,119,221,.25)}

    .footer{text-align:center;padding:2rem 1rem 0;font-size:11px;color:var(--t3)}
    .footer a{color:var(--t3)}

    @media(max-width:500px){
      .row2,.action-row{grid-template-columns:1fr}
      .formats{grid-template-columns:repeat(3,1fr)}
      .scenarios{grid-template-columns:repeat(2,1fr)}
      .steps .slabel{display:none}
    }
  </style>
</head>
<body>

<div class="header">
  <div class="orb" style="width:300px;height:300px;background:#7F77DD;top:-110px;right:-70px"></div>
  <div class="orb" style="width:180px;height:180px;background:#D85A30;bottom:-50px;left:30px"></div>
  <div class="orb" style="width:130px;height:130px;background:#1D9E75;top:25px;left:38%"></div>
  <div class="h-inner">
    <div class="eyebrow"><i class="ti ti-sparkles"></i> Claude AI · Unsplash · Google</div>
    <h1>Estúdio de Arte IA</h1>
    <p>Crie mockups realistas para clientes e posts prontos para suas redes sociais.</p>
    <div class="badges">
      <span class="badge bp"><i class="ti ti-building"></i> Mockup de marca</span>
      <span class="badge bc"><i class="ti ti-brand-instagram"></i> Posts para redes</span>
      <span class="badge bt"><i class="ti ti-wand"></i> Logo por IA</span>
      <span class="badge ba"><i class="ti ti-download"></i> Exporta PNG + SVG</span>
    </div>
  </div>
</div>

<div class="main">

  <!-- ABAS PRINCIPAIS -->
  <div class="main-tabs">
    <div class="main-tab active" id="tab-mockup" onclick="setModule('mockup')">
      <i class="ti ti-layout-collage"></i>
      <span>Mockup de Marca</span>
      <small>Logo em cenário real</small>
    </div>
    <div class="main-tab" id="tab-post" onclick="setModule('post')">
      <i class="ti ti-brand-instagram"></i>
      <span>Post para Redes</span>
      <small>Feed · Story · Banner</small>
    </div>
  </div>

  <!-- ═══════════════════════════════════════ -->
  <!-- MÓDULO 1: MOCKUP                        -->
  <!-- ═══════════════════════════════════════ -->
  <div id="module-mockup" class="module active">
    <div class="steps">
      <div class="step active" id="mst-1" onclick="mGoStep(1)"><div class="snum">1</div><span class="slabel">Empresa</span></div>
      <div class="step" id="mst-2" onclick="mGoStep(2)"><div class="snum">2</div><span class="slabel">Cenário</span></div>
      <div class="step" id="mst-3" onclick="mGoStep(3)"><div class="snum">3</div><span class="slabel">Estilo</span></div>
      <div class="step" id="mst-4" onclick="mGoStep(4)"><div class="snum">4</div><span class="slabel">Resultado</span></div>
    </div>

    <!-- M-PASSO 1 -->
    <div id="mpasso-1" class="mpasso">
      <div class="card">
        <div class="card-title"><i class="ti ti-building"></i> Dados da empresa</div>
        <div class="fg"><div class="flabel"><i class="ti ti-building"></i> Nome</div><input type="text" id="m-nome" placeholder="Ex: Aliança Monitoramento, Café do Bairro..." /></div>
        <div class="row2">
          <div class="fg"><div class="flabel"><i class="ti ti-category"></i> Setor</div>
            <select id="m-setor"><option>Segurança</option><option>Tecnologia</option><option>Saúde</option><option>Educação</option><option>Alimentação</option><option>Moda</option><option>Finanças</option><option>Imóveis</option><option>Beleza</option><option>Esportes</option><option>Varejo</option><option>Outro</option></select>
          </div>
          <div class="fg"><div class="flabel"><i class="ti ti-map-pin"></i> Cidade</div><input type="text" id="m-cidade" placeholder="Ex: Maceió, São Paulo..." /></div>
        </div>
        <div class="fg"><div class="flabel"><i class="ti ti-quote"></i> Slogan</div><input type="text" id="m-slogan" placeholder="Ex: Protegendo o que é seu..." /></div>
      </div>
      <button class="btn-gen" onclick="mGoStep(2)">Próximo — Cenário <i class="ti ti-arrow-right"></i></button>
    </div>

    <!-- M-PASSO 2 -->
    <div id="mpasso-2" class="mpasso" style="display:none">
      <div class="card">
        <div class="card-title"><i class="ti ti-photo"></i> Onde aplicar a marca?</div>
        <div class="scenarios" id="m-scenario-grid"></div>
      </div>
      <div id="m-foto-wrap" style="display:none">
        <div class="card">
          <div class="card-title"><i class="ti ti-photo-search"></i> Imagem do cenário</div>
          <div class="fg"><div class="flabel"><i class="ti ti-database"></i> Fonte</div>
            <div class="source-btns">
              <button class="source-btn active" id="m-src-unsplash" onclick="mSetSource('unsplash')"><i class="ti ti-photo"></i><span>Unsplash</span><small>Cenários gerais</small></button>
              <button class="source-btn" id="m-src-google" onclick="mSetSource('google')"><i class="ti ti-brand-google"></i><span>Google</span><small>Produtos de marca</small></button>
            </div>
          </div>
          <div class="fg"><div class="flabel"><i class="ti ti-search"></i> Busca personalizada</div>
            <div style="display:flex;gap:8px">
              <input type="text" id="m-query-custom" placeholder="Ex: câmera Intelbras, alarme residencial..." style="flex:1"/>
              <button onclick="mBuscarCustom()" style="padding:10px 14px;border-radius:var(--rs);border:1px solid var(--border2);background:var(--pd);color:var(--pl);cursor:pointer;font-size:13px;white-space:nowrap;font-family:Inter,sans-serif;display:flex;align-items:center;gap:5px"><i class="ti ti-search"></i> Buscar</button>
            </div>
          </div>
          <div class="foto-preview" id="m-foto-preview"><img id="m-foto-img" src="" alt="Cenário"/><div class="foto-credit"><i class="ti ti-camera"></i><span id="m-foto-src-label">Foto por</span> <a id="m-foto-credit-link" href="#" target="_blank">–</a></div></div>
          <button class="btn-nova-foto" onclick="mBuscarFoto()"><i class="ti ti-refresh"></i> Outra foto</button>
        </div>
      </div>
      <button class="btn-gen" id="m-btn-step2" onclick="mGoStep(3)" disabled>Próximo — Estilo <i class="ti ti-arrow-right"></i></button>
    </div>

    <!-- M-PASSO 3 -->
    <div id="mpasso-3" class="mpasso" style="display:none">
      <div class="card">
        <div class="card-title"><i class="ti ti-brush"></i> Estilo visual</div>
        <div class="fg"><div class="flabel"><i class="ti ti-palette"></i> Estilo</div>
          <div class="chips" id="m-estilos">
            <span class="chip on" onclick="this.classList.toggle('on')">Moderno</span>
            <span class="chip" onclick="this.classList.toggle('on')">Minimalista</span>
            <span class="chip" onclick="this.classList.toggle('on')">Corporativo</span>
            <span class="chip" onclick="this.classList.toggle('on')">Criativo</span>
            <span class="chip" onclick="this.classList.toggle('on')">Elegante</span>
            <span class="chip" onclick="this.classList.toggle('on')">Bold</span>
            <span class="chip" onclick="this.classList.toggle('on')">Futurista</span>
            <span class="chip" onclick="this.classList.toggle('on')">Tecnológico</span>
          </div>
        </div>
        <div class="fg"><div class="flabel"><i class="ti ti-color-picker"></i> Cor principal</div>
          <div class="color-row" id="m-cores">
            <div class="cpick on" style="background:#7F77DD" data-name="roxo" onclick="mPickColor(this)"></div>
            <div class="cpick" style="background:#D85A30" data-name="coral" onclick="mPickColor(this)"></div>
            <div class="cpick" style="background:#1D9E75" data-name="verde" onclick="mPickColor(this)"></div>
            <div class="cpick" style="background:#378ADD" data-name="azul" onclick="mPickColor(this)"></div>
            <div class="cpick" style="background:#BA7517" data-name="âmbar" onclick="mPickColor(this)"></div>
            <div class="cpick" style="background:#D4537E" data-name="rosa" onclick="mPickColor(this)"></div>
            <div class="cpick" style="background:#C0A060" data-name="dourado" onclick="mPickColor(this)"></div>
            <div class="cpick" style="background:#e8e8e6" data-name="branco" onclick="mPickColor(this)"></div>
          </div>
        </div>
        <div class="fg"><div class="flabel"><i class="ti ti-photo"></i> Tipo de arte</div>
          <select id="m-tipo"><option>Logo / Identidade visual</option><option>Banner institucional</option><option>Post redes sociais</option><option>Cartão de visita</option><option>Placa / Sinalização</option></select>
        </div>
        <div class="fg"><div class="flabel"><i class="ti ti-notes"></i> Detalhes extras</div>
          <textarea id="m-extra" placeholder="Valores da marca, público-alvo, referências..."></textarea>
        </div>
      </div>
      <button class="btn-gen" onclick="mGerar()"><i class="ti ti-wand"></i> Gerar mockup agora</button>
    </div>

    <!-- M-PASSO 4: RESULTADO -->
    <div id="mpasso-4" class="mpasso" style="display:none">
      <div class="result-wrap">
        <div class="result-bar">
          <div class="result-bar-l"><div class="sdot" id="m-sdot"></div><span id="m-result-label">Gerando...</span></div>
          <span class="rtag" id="m-rtag">–</span>
        </div>
        <div>
          <div class="loading-box" id="m-loading"><div class="spin"></div><div class="lmsg" id="m-lmsg">Buscando foto...</div><div class="lsteps"><div class="lstep pulse" id="m-ls0"></div><div class="lstep" id="m-ls1"></div><div class="lstep" id="m-ls2"></div><div class="lstep" id="m-ls3"></div></div></div>
          <div class="output-box" id="m-output" style="display:none">
            <div class="mockup-wrap"><img class="mockup-bg" id="m-mockup-bg" src="" alt=""/><div class="mockup-overlay"><div id="m-svg-canvas"></div></div><div class="mockup-badge" id="m-mockup-badge">📸 Unsplash</div></div>
            <div class="desc-card"><div class="desc-label"><i class="ti ti-info-circle"></i> Sobre este mockup</div><p id="m-desc"></p></div>
            <div class="action-row">
              <button class="btn-sec" onclick="mGerar()"><i class="ti ti-refresh"></i> Nova versão</button>
              <button class="btn-sec" onclick="mNovaFoto()"><i class="ti ti-camera"></i> Outra foto</button>
              <button class="btn-sec" onclick="mExportPNG()"><i class="ti ti-download"></i> Baixar PNG</button>
            </div>
            <div style="margin-top:8px"><button class="btn-sec" style="width:100%" onclick="mExportSVG()"><i class="ti ti-vector"></i> Baixar logo SVG</button></div>
          </div>
          <div class="error-box" id="m-error" style="display:none"><div class="error-icon"><i class="ti ti-alert-circle"></i></div><div class="error-msg" id="m-error-msg">Erro.</div><button class="btn-retry" onclick="mGerar()"><i class="ti ti-refresh"></i> Tentar novamente</button></div>
        </div>
      </div>
      <button class="btn-back" onclick="mGoStep(1)"><i class="ti ti-arrow-left"></i> Criar outro mockup</button>
    </div>
  </div>

  <!-- ═══════════════════════════════════════ -->
  <!-- MÓDULO 2: POSTS PARA REDES SOCIAIS      -->
  <!-- ═══════════════════════════════════════ -->
  <div id="module-post" class="module">
    <div class="steps">
      <div class="step active" id="pst-1" onclick="pGoStep(1)"><div class="snum">1</div><span class="slabel">Empresa</span></div>
      <div class="step" id="pst-2" onclick="pGoStep(2)"><div class="snum">2</div><span class="slabel">Formato</span></div>
      <div class="step" id="pst-3" onclick="pGoStep(3)"><div class="snum">3</div><span class="slabel">Conteúdo</span></div>
      <div class="step" id="pst-4" onclick="pGoStep(4)"><div class="snum">4</div><span class="slabel">Resultado</span></div>
    </div>

    <!-- P-PASSO 1 -->
    <div id="ppasso-1" class="ppasso">
      <div class="card">
        <div class="card-title"><i class="ti ti-building"></i> Dados da empresa</div>
        <div class="fg"><div class="flabel"><i class="ti ti-building"></i> Nome da empresa</div><input type="text" id="p-nome" placeholder="Ex: Aliança Monitoramento, Café do Bairro..."/></div>
        <div class="row2">
          <div class="fg"><div class="flabel"><i class="ti ti-category"></i> Setor</div>
            <select id="p-setor"><option>Segurança</option><option>Tecnologia</option><option>Saúde</option><option>Educação</option><option>Alimentação</option><option>Moda</option><option>Finanças</option><option>Imóveis</option><option>Beleza</option><option>Esportes</option><option>Varejo</option><option>Outro</option></select>
          </div>
          <div class="fg"><div class="flabel"><i class="ti ti-color-picker"></i> Cor principal</div>
            <div class="color-row" id="p-cores">
              <div class="cpick on" style="background:#7F77DD" data-name="roxo" onclick="pPickColor(this)"></div>
              <div class="cpick" style="background:#D85A30" data-name="coral" onclick="pPickColor(this)"></div>
              <div class="cpick" style="background:#1D9E75" data-name="verde" onclick="pPickColor(this)"></div>
              <div class="cpick" style="background:#378ADD" data-name="azul" onclick="pPickColor(this)"></div>
              <div class="cpick" style="background:#BA7517" data-name="âmbar" onclick="pPickColor(this)"></div>
              <div class="cpick" style="background:#D4537E" data-name="rosa" onclick="pPickColor(this)"></div>
              <div class="cpick" style="background:#C0A060" data-name="dourado" onclick="pPickColor(this)"></div>
              <div class="cpick" style="background:#222" data-name="preto" onclick="pPickColor(this)"></div>
            </div>
          </div>
        </div>
        <div class="fg"><div class="flabel"><i class="ti ti-quote"></i> Slogan ou frase da marca</div><input type="text" id="p-slogan" placeholder="Ex: Protegendo o que é seu, Sabor que conecta..."/></div>
      </div>
      <button class="btn-gen" onclick="pGoStep(2)">Próximo — Formato <i class="ti ti-arrow-right"></i></button>
    </div>

    <!-- P-PASSO 2: FORMATO -->
    <div id="ppasso-2" class="ppasso" style="display:none">
      <div class="card">
        <div class="card-title"><i class="ti ti-layout"></i> Formato do post</div>
        <div class="formats">
          <div class="fmt-card active" id="fmt-feed" onclick="pSetFormato('feed')">
            <div class="fmt-preview" style="width:60px;height:60px"></div>
            <span class="fmt-label">Feed</span>
            <span class="fmt-dim">1080×1080</span>
            <div class="fmt-check">✓</div>
          </div>
          <div class="fmt-card" id="fmt-story" onclick="pSetFormato('story')">
            <div class="fmt-preview" style="width:34px;height:60px"></div>
            <span class="fmt-label">Story</span>
            <span class="fmt-dim">1080×1920</span>
            <div class="fmt-check">✓</div>
          </div>
          <div class="fmt-card" id="fmt-banner" onclick="pSetFormato('banner')">
            <div class="fmt-preview" style="width:80px;height:45px"></div>
            <span class="fmt-label">Banner</span>
            <span class="fmt-dim">1200×628</span>
            <div class="fmt-check">✓</div>
          </div>
        </div>
      </div>
      <button class="btn-gen" onclick="pGoStep(3)">Próximo — Conteúdo <i class="ti ti-arrow-right"></i></button>
    </div>

    <!-- P-PASSO 3: CONTEÚDO -->
    <div id="ppasso-3" class="ppasso" style="display:none">
      <div class="card">
        <div class="card-title"><i class="ti ti-bulb"></i> Tipo de conteúdo</div>
        <div class="tipo-grid">
          <div class="tipo-card active" id="tipo-promo" onclick="pSetTipo('promo')"><span class="tipo-icon">🔥</span><span class="tipo-label">Promoção</span></div>
          <div class="tipo-card" id="tipo-dica" onclick="pSetTipo('dica')"><span class="tipo-icon">💡</span><span class="tipo-label">Dica</span></div>
          <div class="tipo-card" id="tipo-produto" onclick="pSetTipo('produto')"><span class="tipo-icon">📦</span><span class="tipo-label">Produto</span></div>
          <div class="tipo-card" id="tipo-frase" onclick="pSetTipo('frase')"><span class="tipo-icon">✨</span><span class="tipo-label">Frase</span></div>
          <div class="tipo-card" id="tipo-inst" onclick="pSetTipo('inst')"><span class="tipo-icon">🏢</span><span class="tipo-label">Institucional</span></div>
        </div>
      </div>
      <div class="card">
        <div class="card-title"><i class="ti ti-pencil"></i> Detalhes do conteúdo</div>
        <div class="fg"><div class="flabel"><i class="ti ti-brush"></i> Estilo visual</div>
          <div class="chips" id="p-estilos">
            <span class="chip on" onclick="this.classList.toggle('on')">Moderno</span>
            <span class="chip" onclick="this.classList.toggle('on')">Minimalista</span>
            <span class="chip" onclick="this.classList.toggle('on')">Bold</span>
            <span class="chip" onclick="this.classList.toggle('on')">Elegante</span>
            <span class="chip" onclick="this.classList.toggle('on')">Colorido</span>
            <span class="chip" onclick="this.classList.toggle('on')">Dark</span>
            <span class="chip" onclick="this.classList.toggle('on')">Gradiente</span>
          </div>
        </div>
        <div class="fg"><div class="flabel"><i class="ti ti-notes"></i> Texto principal do post</div>
          <textarea id="p-texto" placeholder="Ex: 50% OFF em câmeras de segurança! Só essa semana. Peça já o seu orçamento."></textarea>
        </div>
        <div class="fg"><div class="flabel"><i class="ti ti-phone"></i> Contato / CTA (opcional)</div>
          <input type="text" id="p-contato" placeholder="Ex: (82) 99999-9999 · @aliancamonitoramento"/>
        </div>
      </div>
      <button class="btn-gen" onclick="pGerar()"><i class="ti ti-wand"></i> Criar post agora</button>
    </div>

    <!-- P-PASSO 4: RESULTADO -->
    <div id="ppasso-4" class="ppasso" style="display:none">
      <div class="result-wrap">
        <div class="result-bar">
          <div class="result-bar-l"><div class="sdot" id="p-sdot"></div><span id="p-result-label">Gerando post...</span></div>
          <span class="rtag" id="p-rtag">Feed</span>
        </div>
        <div>
          <div class="loading-box" id="p-loading"><div class="spin"></div><div class="lmsg" id="p-lmsg">A IA está criando seu post...</div><div class="lsteps"><div class="lstep pulse" id="p-ls0"></div><div class="lstep" id="p-ls1"></div><div class="lstep" id="p-ls2"></div><div class="lstep" id="p-ls3"></div></div></div>
          <div class="output-box" id="p-output" style="display:none">
            <div class="post-frame" id="p-post-frame"></div>
            <div class="desc-card"><div class="desc-label"><i class="ti ti-info-circle"></i> Sobre este post</div><p id="p-desc"></p></div>
            <div class="action-row-2">
              <button class="btn-sec" onclick="pGerar()"><i class="ti ti-refresh"></i> Nova versão</button>
              <button class="btn-sec" onclick="pExportPNG()"><i class="ti ti-download"></i> Baixar PNG</button>
            </div>
            <div style="margin-top:8px"><button class="btn-sec" style="width:100%" onclick="pExportSVG()"><i class="ti ti-vector"></i> Baixar SVG</button></div>
          </div>
          <div class="error-box" id="p-error" style="display:none"><div class="error-icon"><i class="ti ti-alert-circle"></i></div><div class="error-msg" id="p-error-msg">Erro.</div><button class="btn-retry" onclick="pGerar()"><i class="ti ti-refresh"></i> Tentar novamente</button></div>
        </div>
      </div>
      <button class="btn-back" onclick="pGoStep(1)"><i class="ti ti-arrow-left"></i> Criar outro post</button>
    </div>
  </div>

  <div class="footer">Estúdio de Arte IA · <a href="https://anthropic.com" target="_blank">Claude AI</a> · <a href="https://unsplash.com" target="_blank">Unsplash</a> · Google Images</div>
</div>

<script>
// ═══════════════════════════════════
// ESTADO GLOBAL
// ═══════════════════════════════════
let currentModule = 'mockup';
// Mockup
let mStep=1, mScenario=null, mFoto=null, mSvg='', mSource='unsplash', mCustomQ='', mTimer, mIdx=0, mGenerating=false;
// Post
let pStep=1, pFormato='feed', pTipo='promo', pSvg='', pTimer, pIdx=0, pGenerating=false;

const CENARIOS = [
  {id:'fachada',   label:'Fachada de loja',    icon:'ti-door-enter',         query:'retail store front exterior'},
  {id:'seguranca', label:'Câmera de segurança', icon:'ti-camera',             query:'security camera cctv installation'},
  {id:'outdoor',   label:'Outdoor / Placa',     icon:'ti-sign-left',          query:'billboard outdoor advertisement'},
  {id:'escritorio',label:'Escritório',          icon:'ti-building-skyscraper',query:'modern office interior'},
  {id:'cartao',    label:'Mesa / Cartão',       icon:'ti-id-badge',           query:'business card desk minimal'},
  {id:'celular',   label:'Tela de app',         icon:'ti-device-mobile',      query:'smartphone app screen hand'},
  {id:'uniforme',  label:'Uniforme',            icon:'ti-shirt',              query:'work uniform employee professional'},
  {id:'veiculo',   label:'Veículo / Frota',     icon:'ti-car',                query:'branded company car fleet'},
  {id:'restaurante',label:'Restaurante',        icon:'ti-coffee',             query:'restaurant cafe interior'},
];

const FORMATOS = {
  feed:   {w:500, h:500,  label:'Feed 1:1',    vb:'0 0 500 500'},
  story:  {w:300, h:530,  label:'Story 9:16',  vb:'0 0 300 530'},
  banner: {w:600, h:314,  label:'Banner 1.91:1',vb:'0 0 600 314'},
};

const TIPOS = {
  promo:   'Promoção / Oferta especial',
  dica:    'Dica / Conteúdo educativo',
  produto: 'Apresentação de produto ou serviço',
  frase:   'Frase motivacional / institucional',
  inst:    'Post institucional / sobre a empresa',
};

// ═══════════════════════════════════
// NAVEGAÇÃO ENTRE MÓDULOS
// ═══════════════════════════════════
function setModule(m) {
  currentModule = m;
  document.getElementById('tab-mockup').classList.toggle('active', m==='mockup');
  document.getElementById('tab-post').classList.toggle('active', m==='post');
  document.getElementById('module-mockup').classList.toggle('active', m==='mockup');
  document.getElementById('module-post').classList.toggle('active', m==='post');
}

// ═══════════════════════════════════
// MÓDULO MOCKUP
// ═══════════════════════════════════
function mGoStep(n) {
  if(n>1 && !document.getElementById('m-nome').value.trim()){
    const el=document.getElementById('m-nome'); el.focus(); el.style.borderColor='#E24B4A'; setTimeout(()=>el.style.borderColor='',2000); return;
  }
  if(n>2 && !mScenario) return;
  mStep=n;
  document.querySelectorAll('.mpasso').forEach((p,i)=>p.style.display=i+1===n?'block':'none');
  document.querySelectorAll('[id^="mst-"]').forEach((s,i)=>{s.classList.toggle('active',i+1===n);s.classList.toggle('done',i+1<n);});
  window.scrollTo({top:0,behavior:'smooth'});
}

document.addEventListener('DOMContentLoaded',()=>{
  const grid=document.getElementById('m-scenario-grid');
  grid.innerHTML=CENARIOS.map(c=>`
    <div class="scenario-card" id="sc-${c.id}" onclick="mSelectScenario('${c.id}')">
      <div class="scenario-thumb"><i class="ti ${c.icon}" style="font-size:26px;color:#5a5490"></i></div>
      <div class="scenario-label"><i class="ti ${c.icon}"></i>${c.label}</div>
      <div class="scenario-check">✓</div>
    </div>`).join('');
});

async function mSelectScenario(id){
  mScenario=CENARIOS.find(c=>c.id===id);
  document.querySelectorAll('.scenario-card').forEach(c=>c.classList.remove('active'));
  document.getElementById('sc-'+id).classList.add('active');
  document.getElementById('m-btn-step2').disabled=false;
  document.getElementById('m-foto-wrap').style.display='block';
  await mBuscarFoto();
}

function mSetSource(src){
  mSource=src;
  document.getElementById('m-src-unsplash').classList.toggle('active',src==='unsplash');
  document.getElementById('m-src-google').classList.toggle('active',src==='google');
  if(mScenario||mCustomQ) mBuscarFoto();
}

async function mBuscarCustom(){
  const v=document.getElementById('m-query-custom').value.trim();
  if(!v) return; mCustomQ=v; await mBuscarFoto();
}

async function mBuscarFoto(){
  if(!mScenario&&!mCustomQ) return;
  const prev=document.getElementById('m-foto-preview'); prev.style.opacity='.5';
  const q=mCustomQ||mScenario?.query||'business';
  const ep=mSource==='google'?`/api/foto/google?q=${encodeURIComponent(q)}`:`/api/foto/unsplash?q=${encodeURIComponent(q)}`;
  try{
    const r=await fetch(ep); const d=await r.json();
    if(d.error) throw new Error(d.error);
    mFoto=d;
    document.getElementById('m-foto-img').src=d.thumb||d.url;
    const lk=document.getElementById('m-foto-credit-link');
    const sl=document.getElementById('m-foto-src-label');
    if(mSource==='google'){sl.textContent='🔍 Via Google ·';lk.textContent=d.credit||'Google';lk.href=d.creditLink||'#';}
    else{sl.textContent='📷 Foto por';lk.textContent=d.credit||'Unsplash';lk.href=(d.creditLink||'https://unsplash.com')+'?utm_source=estudio&utm_medium=referral';}
    prev.style.opacity='1';
    if(mScenario){const t=document.querySelector(`#sc-${mScenario.id} .scenario-thumb`);if(t){t.style.background=`url(${d.thumb||d.url}) center/cover`;t.innerHTML='';}}
  }catch(e){prev.style.opacity='1';console.error(e);}
}

function mPickColor(el){document.querySelectorAll('#m-cores .cpick').forEach(c=>c.classList.remove('on'));el.classList.add('on');}
function mGetChips(id){return Array.from(document.querySelectorAll('#'+id+' .chip.on')).map(c=>c.textContent.trim()).join(', ');}

const M_MSGS=['Buscando foto do cenário...','Criando o logo com IA...','Compondo formas e cores...','Montando o mockup final...'];
function mStartLoader(){mIdx=0;document.getElementById('m-lmsg').textContent=M_MSGS[0];clearInterval(mTimer);mTimer=setInterval(()=>{document.querySelectorAll('[id^="m-ls"]').forEach((e,i)=>e.classList.toggle('pulse',i===mIdx%4));mIdx++;document.getElementById('m-lmsg').textContent=M_MSGS[mIdx%M_MSGS.length];},1800);}
function mStopLoader(){clearInterval(mTimer);}

async function mGerar(){
  if(mGenerating) return; mGenerating=true;
  mGoStep(4);
  const dot=document.getElementById('m-sdot'); dot.className='sdot';
  document.getElementById('m-result-label').textContent='Gerando mockup...';
  document.getElementById('m-rtag').textContent=mScenario?.label||'–';
  document.getElementById('m-loading').style.display='block';
  document.getElementById('m-output').style.display='none';
  document.getElementById('m-error').style.display='none';
  mStartLoader();
  try{
    if(!mFoto) await mBuscarFoto();
    const nome=document.getElementById('m-nome').value||'Minha Empresa';
    const setor=document.getElementById('m-setor').value;
    const slogan=document.getElementById('m-slogan').value;
    const estilos=mGetChips('m-estilos')||'moderno';
    const cor=document.querySelector('#m-cores .cpick.on')?.dataset.name||'roxo';
    const tipo=document.getElementById('m-tipo').value;
    const extra=document.getElementById('m-extra').value;
    const cenario=mScenario?.label||'ambiente profissional';
    const prompt=`Crie um SVG profissional de logo para a empresa "${nome}" (${setor}).${slogan?' Slogan: '+slogan+'.':''} Tipo: ${tipo}. Estilo: ${estilos}. Cor: ${cor}. Contexto: mockup de ${cenario}.${extra?' Detalhes: '+extra+'.':''}
Dimensões 500x300 viewBox="0 0 500 300". Fundo transparente ou semi-transparente. Nome em destaque, ícone do setor. Funciona sobre foto de fundo.
Retorne APENAS o SVG completo.
Depois escreva "===DESC===" e 2 frases descrevendo as escolhas criativas em português.`;
    const res=await fetch('/api/generate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:4000,messages:[{role:'user',content:prompt}]})});
    const data=await res.json(); mStopLoader();
    if(!res.ok||data.error) throw new Error(data.error?.message||'Erro da API');
    const full=data.content.map(b=>b.text||'').join('');
    const parts=full.split('===DESC==='); let raw=parts[0].trim();
    const desc=parts[1]?.trim()||'Arte criada!';
    const m2=raw.match(/<svg[\s\S]*?<\/svg>/i); if(m2) raw=m2[0];
    if(!raw.includes('<svg')) throw new Error('SVG inválido. Tente novamente.');
    mSvg=raw;
    document.getElementById('m-mockup-bg').src=mFoto?.url||mFoto?.thumb||'';
    const canvas=document.getElementById('m-svg-canvas'); canvas.innerHTML=raw;
    const svgEl=canvas.querySelector('svg'); if(svgEl){svgEl.style.maxWidth='100%';svgEl.style.height='auto';}
    if(mFoto?.credit) document.getElementById('m-mockup-badge').textContent=`📸 ${mFoto.credit}`;
    document.getElementById('m-desc').textContent=desc;
    dot.className='sdot ok'; document.getElementById('m-result-label').textContent='Mockup criado!';
    document.getElementById('m-loading').style.display='none'; document.getElementById('m-output').style.display='block';
  }catch(e){
    mStopLoader(); dot.className='sdot err'; document.getElementById('m-result-label').textContent='Erro';
    document.getElementById('m-error-msg').textContent=e.message;
    document.getElementById('m-loading').style.display='none'; document.getElementById('m-error').style.display='block';
    console.error(e);
  }finally{mGenerating=false;}
}

async function mNovaFoto(){await mBuscarFoto();if(mFoto){document.getElementById('m-mockup-bg').src=mFoto.url||mFoto.thumb;if(mFoto.credit)document.getElementById('m-mockup-badge').textContent=`📸 ${mFoto.credit}`;}}

function mExportSVG(){if(!mSvg)return;const b=new Blob([mSvg],{type:'image/svg+xml'});const u=URL.createObjectURL(b);const a=document.createElement('a');a.href=u;a.download=(document.getElementById('m-nome')?.value||'logo').toLowerCase().replace(/\s+/g,'-')+'-logo.svg';a.click();URL.revokeObjectURL(u);}

async function mExportPNG(){
  try{
    const canvas=document.createElement('canvas'); canvas.width=800;canvas.height=450;
    const ctx=canvas.getContext('2d');
    const img=new Image(); img.crossOrigin='anonymous';
    img.onload=()=>{
      ctx.drawImage(img,0,0,800,450);ctx.fillStyle='rgba(0,0,0,0.35)';ctx.fillRect(0,0,800,450);
      const sd=new XMLSerializer().serializeToString(document.querySelector('#m-svg-canvas svg'));
      const sb=new Blob([sd],{type:'image/svg+xml;charset=utf-8'});const su=URL.createObjectURL(sb);
      const si=new Image();
      si.onload=()=>{const sw=Math.min(400,si.width);const sh=(si.height/si.width)*sw;ctx.drawImage(si,(800-sw)/2,(450-sh)/2,sw,sh);URL.revokeObjectURL(su);const a=document.createElement('a');a.download=(document.getElementById('m-nome')?.value||'mockup').toLowerCase().replace(/\s+/g,'-')+'-mockup.png';a.href=canvas.toDataURL('image/png');a.click();};
      si.src=su;
    };
    img.onerror=()=>alert('Erro CORS na foto. Use o SVG.');
    img.src=document.getElementById('m-mockup-bg').src;
  }catch(e){console.error(e);alert('Erro ao exportar.');}
}

// ═══════════════════════════════════
// MÓDULO POST REDES SOCIAIS
// ═══════════════════════════════════
function pGoStep(n){
  if(n>1&&!document.getElementById('p-nome').value.trim()){
    const el=document.getElementById('p-nome');el.focus();el.style.borderColor='#E24B4A';setTimeout(()=>el.style.borderColor='',2000);return;
  }
  pStep=n;
  document.querySelectorAll('.ppasso').forEach((p,i)=>p.style.display=i+1===n?'block':'none');
  document.querySelectorAll('[id^="pst-"]').forEach((s,i)=>{s.classList.toggle('active',i+1===n);s.classList.toggle('done',i+1<n);});
  window.scrollTo({top:0,behavior:'smooth'});
}

function pSetFormato(f){
  pFormato=f;
  ['feed','story','banner'].forEach(k=>document.getElementById('fmt-'+k).classList.toggle('active',k===f));
}

function pSetTipo(t){
  pTipo=t;
  ['promo','dica','produto','frase','inst'].forEach(k=>document.getElementById('tipo-'+k).classList.toggle('active',k===t));
}

function pPickColor(el){document.querySelectorAll('#p-cores .cpick').forEach(c=>c.classList.remove('on'));el.classList.add('on');}
function pGetChips(id){return Array.from(document.querySelectorAll('#'+id+' .chip.on')).map(c=>c.textContent.trim()).join(', ');}

const P_MSGS=['A IA está criando seu post...','Compondo layout e tipografia...','Adicionando elementos visuais...','Finalizando o post...'];
function pStartLoader(){pIdx=0;document.getElementById('p-lmsg').textContent=P_MSGS[0];clearInterval(pTimer);pTimer=setInterval(()=>{document.querySelectorAll('[id^="p-ls"]').forEach((e,i)=>e.classList.toggle('pulse',i===pIdx%4));pIdx++;document.getElementById('p-lmsg').textContent=P_MSGS[pIdx%P_MSGS.length];},1800);}
function pStopLoader(){clearInterval(pTimer);}

async function pGerar(){
  if(pGenerating) return; pGenerating=true;
  pGoStep(4);
  const dot=document.getElementById('p-sdot'); dot.className='sdot';
  document.getElementById('p-result-label').textContent='Gerando post...';
  const fmt=FORMATOS[pFormato];
  document.getElementById('p-rtag').textContent=fmt.label;
  document.getElementById('p-loading').style.display='block';
  document.getElementById('p-output').style.display='none';
  document.getElementById('p-error').style.display='none';
  pStartLoader();
  try{
    const nome=document.getElementById('p-nome').value||'Minha Empresa';
    const setor=document.getElementById('p-setor').value;
    const cor=document.querySelector('#p-cores .cpick.on')?.dataset.name||'roxo';
    const slogan=document.getElementById('p-slogan').value;
    const estilos=pGetChips('p-estilos')||'moderno';
    const texto=document.getElementById('p-texto').value;
    const contato=document.getElementById('p-contato').value;
    const tipoDesc=TIPOS[pTipo];
    const prompt=`Você é um designer de redes sociais especialista em identidade visual brasileira.
Crie um SVG de POST para redes sociais para a empresa "${nome}" (${setor}).
Tipo de conteúdo: ${tipoDesc}.
Formato: ${fmt.label} — viewBox="${fmt.vb}" (use EXATAMENTE este viewBox).
Estilo visual: ${estilos}. Cor principal: ${cor}.
${slogan?'Slogan da marca: '+slogan+'.':''}
${texto?'Texto principal do post: '+texto:''}
${contato?'Contato/CTA: '+contato:''}

REGRAS OBRIGATÓRIAS:
- viewBox EXATAMENTE "${fmt.vb}"
- Fundo com cor sólida ou gradiente (NÃO transparente — é um post completo)
- Nome da empresa visível e em destaque
- Layout profissional para ${fmt.label==='Story 9:16'?'formato vertical story':'formato '+fmt.label}
- Tipografia limpa, legível, hierarquia visual clara
- Elementos decorativos que reforcem o setor (${setor})
- Se tiver texto do post, incorpore ele de forma visualmente atraente
- Se tiver contato/CTA, coloque em destaque no final
- Qualidade profissional, pronto para publicar

Retorne APENAS o SVG completo sem markdown.
Depois escreva "===DESC===" e 2 frases sobre as escolhas de design em português.`;

    const res=await fetch('/api/generate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:4000,messages:[{role:'user',content:prompt}]})});
    const data=await res.json(); pStopLoader();
    if(!res.ok||data.error) throw new Error(data.error?.message||'Erro da API');
    const full=data.content.map(b=>b.text||'').join('');
    const parts=full.split('===DESC==='); let raw=parts[0].trim();
    const desc=parts[1]?.trim()||'Post criado com sucesso!';
    const m2=raw.match(/<svg[\s\S]*?<\/svg>/i); if(m2) raw=m2[0];
    if(!raw.includes('<svg')) throw new Error('SVG inválido. Tente novamente.');
    pSvg=raw;
    const frame=document.getElementById('p-post-frame'); frame.innerHTML=raw;
    const svgEl=frame.querySelector('svg');
    if(svgEl){svgEl.style.maxWidth='100%';svgEl.style.height='auto';svgEl.style.borderRadius='8px';}
    document.getElementById('p-desc').textContent=desc;
    dot.className='sdot ok'; document.getElementById('p-result-label').textContent='Post criado!';
    document.getElementById('p-loading').style.display='none'; document.getElementById('p-output').style.display='block';
  }catch(e){
    pStopLoader(); dot.className='sdot err'; document.getElementById('p-result-label').textContent='Erro';
    document.getElementById('p-error-msg').textContent=e.message;
    document.getElementById('p-loading').style.display='none'; document.getElementById('p-error').style.display='block';
    console.error(e);
  }finally{pGenerating=false;}
}

function pExportSVG(){if(!pSvg)return;const b=new Blob([pSvg],{type:'image/svg+xml'});const u=URL.createObjectURL(b);const a=document.createElement('a');a.href=u;a.download=(document.getElementById('p-nome')?.value||'post').toLowerCase().replace(/\s+/g,'-')+'-post.svg';a.click();URL.revokeObjectURL(u);}

async function pExportPNG(){
  if(!pSvg) return;
  try{
    const fmt=FORMATOS[pFormato];
    const scale=2;
    const canvas=document.createElement('canvas'); canvas.width=fmt.w*scale; canvas.height=fmt.h*scale;
    const ctx=canvas.getContext('2d'); ctx.scale(scale,scale);
    const sd=pSvg.replace(/viewBox="[^"]*"/,`viewBox="${fmt.vb}"`);
    const sb=new Blob([sd],{type:'image/svg+xml;charset=utf-8'});const su=URL.createObjectURL(sb);
    const si=new Image(); si.width=fmt.w; si.height=fmt.h;
    si.onload=()=>{
      ctx.drawImage(si,0,0,fmt.w,fmt.h); URL.revokeObjectURL(su);
      const a=document.createElement('a');
      a.download=(document.getElementById('p-nome')?.value||'post').toLowerCase().replace(/\s+/g,'-')+'-'+pFormato+'.png';
      a.href=canvas.toDataURL('image/png'); a.click();
    };
    si.onerror=()=>alert('Erro ao exportar PNG. Use o SVG.');
    si.src=su;
  }catch(e){console.error(e);alert('Erro ao exportar.');}
}
</script>
</body>
</html>
